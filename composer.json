{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravelsecurityaudit/laravel-mail-preview",
    "description": "Database-backed mail preview inbox for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrei Artiushenko",
            "homepage": "https://laravelsecurityaudit.com"
        }
    ],
    "homepage": "https://github.com/workaandrey/laravel-mail-preview",
    "support": {
        "issues": "https://github.com/workaandrey/laravel-mail-preview/issues",
        "source": "https://github.com/workaandrey/laravel-mail-preview"
    },
    "keywords": [
        "laravel",
        "mail",
        "email",
        "preview",
        "testing"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/events": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/mail": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/view": "^11.0 || ^12.0 || ^13.0",
        "symfony/mime": "^7.0 || ^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.5"
    },
    "autoload": {
        "psr-4": {
            "LaravelSecurityAudit\\MailPreview\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelSecurityAudit\\MailPreview\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelSecurityAudit\\MailPreview\\MailPreviewServiceProvider"
            ]
        }
    },
    "scripts": {
        "format": "pint",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
